# Copy to `.env` and set to your API host (same LAN as this dev machine).
# Used only by the Vite dev server proxy (`npm run dev`). Production builds use your
# reverse proxy or whatever serves `/api` → mediamonitor-api.
#
# Example:
# VITE_DEV_API_TARGET=http://192.168.5.97:8787
# VITE_DEV_API_TARGET=http://olympia.local:8787
VITE_DEV_API_TARGET=http://127.0.0.1:8787
